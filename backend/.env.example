APP_NAME=VTU CIE App API
ENVIRONMENT=dev
AUTO_CREATE_SCHEMA=true
AUTO_SEED_DATA=true
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=120
REFRESH_TOKEN_DAYS=14
UPLOAD_ROOT=./uploads

# Local default (SQLite):
DATABASE_URL=sqlite:///./vtu_cie.db

# PostgreSQL profile (uncomment and update for deployment):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/vtu_cie
# AUTO_CREATE_SCHEMA=false
# AUTO_SEED_DATA=false
